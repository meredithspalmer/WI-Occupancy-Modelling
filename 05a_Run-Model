                                    #coeff_var = static$log_coeff_var,
                                    trend     = trend),
                    det.covs = list(effort = effort_array,        # already scaled! 
                                    minjul = minjul,              # already scaled! 
                                    minjul_sq = minjul_sq,        # already scaled! 
                                    ndepl = ndepl, 
                                    proj = proj),
                    coords = coords)

dat_ls_mod2 <- list(y = y_array,
                    occ.covs = list(wdpa      = wdpa_model, 
