                                    ndepl = ndepl, 
                                    proj = proj),
                    coords = coords)

# Model formulas ---
occ.formula_mod1 = ~ scale(encroach) + scale(ghm) + scale(evi) + scale(forest) + 
  scale(precip) + scale(temp) + scale(tri) + scale(trend) # + scale(coeff_var)

occ.formula_mod2 = ~ scale(wdpa) + scale(evi) + scale(forest) + scale(precip) + 
  scale(temp) + scale(tri) + scale(coeff_var) + scale(trend) 

det.formula = ~ effort + minjul + minjul_sq + ndepl + (1|proj) #already scaled 

# Covariates whose effects are estimated as SVCs, including intercept
svc.cols_mod1 = c(1:9)  
svc.cols_mod2 = c(1:8)

# Prep inits ---
z.init <- apply(y_array, c(1, 2), function(a) as.numeric(sum(a, na.rm = TRUE) > 0))
dist.data <- dist(coords)            

inits.list_mod1 <- list(beta = 0,            # occurrence coefficients
                        alpha = 0,           # detection coefficients
                        z = z.init,          # latent occurrence values
                        phi = 3 / mean(dist.data),  
                        sigma.sq = 0.5,      
                        w = matrix(0, length(svc.cols_mod1), nrow(y_array)),  
                        #rho = 0,  
                        sigma.sq.t = 0.5)    # occurrence random effect variances 
inits.list_mod2 <- list(beta = 0,            # occurrence coefficients
                        alpha = 0,           # detection coefficients
                        z = z.init,          # latent occurrence values
                        phi = 3 / mean(dist.data),  
                        sigma.sq = 0.5,      
                        w = matrix(0, length(svc.cols_mod2), nrow(y_array)),  
                        #rho = 0,  
                        sigma.sq.t = 0.5)    # occurrence random effect variances 

priors.list <- list(alpha.normal = list(mean = 0, var = 2.72), 
                    beta.normal = list(mean = 0, var = 2.72),
                    sigma.sq.ig = list(a = 2, b = 0.5),
                    phi.unif = list(a = 3 / max(dist.data), 
                                    b = 3 / min(dist.data)))

