  reference_species <- crop(global_cell_id, ext(mmd_aligned))
  reference_species <- mask(reference_species, mmd_aligned)  
  reference_species; plot(reference_species)
  
  
  ## Generate WI data for modelling ---------------------------------------------
  
  # Subset to species data found within range map 
  dat_sp_vect <- vect(dat_sp, geom = c("longitude", "latitude"), crs = "EPSG:4326")
  
  # Transform points to raster CRS if needed
  if (!compareCRS(dat_sp_vect, mmd_map)) {
    dat_sp_vect <- project(dat_sp_vect, crs(mmd_map))
  }
  
  # Extract raster values and filter points inside raster
