  if (!target_species %in% names(truncation_dates)) {
    cat("No truncation date defined for", target_species, "→ using full dataset\n")
    
  } else {
    
    set_date <- truncation_dates[[target_species]]
    
    cat("Applying temporal truncation for", target_species, 
