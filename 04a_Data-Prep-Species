  ## Check start and end dates --------------------------------------------------
  
  # Check for dates out of range 
  setDT(dat); setDT(dat_sp)
  dat <- dat %>% filter(sensor_end_date <= as.Date("2024-09-30"))
  dat_sp <- dat_sp %>% filter(sensor_end_date <= as.Date("2024-09-30"))
  
  # Check for sensor end dates before sensor start dates 
  dat[, bad_deployment := sensor_end_date < sensor_start_date]
  dat[bad_deployment == TRUE, .N]
  
  dat_sp[, bad_deployment := sensor_end_date < sensor_start_date]
  dat_sp[bad_deployment == TRUE, .N]
  
  # Clean any bad dates (rep for dat_sp if necessary)
  dat[bad_deployment == TRUE, `:=`(
    sensor_start_date = pmin(sensor_start_date, sensor_end_date),
    sensor_end_date   = pmax(sensor_start_date, sensor_end_date)
  )]
