## Generate (dynamic) periods -------------------------------------------------

# Start and end dates from data
min_start <- min(dat$sensor_start_date)
max_end   <- max(dat$sensor_end_date)

start_dec <- as.IDate(paste(year(min_start) - 1, "12-01", sep = "-"))
period_starts <- seq(start_dec, max_end, by = "91 days")

period_starts <- as.Date(period_starts)  
n_periods <- length(period_starts)

periods_dynamic <- data.table(
  start_period = period_starts,
  end_period   = c(period_starts[-1] - 1, NA_Date_)   
)[!is.na(end_period)]

periods_dynamic[, `:=`(
  period = paste0("Period_", .I),
  season = rep(c("Winter", "Spring", "Summer", "Fall"), length.out = .N),
  year = year(start_period) + ifelse(month(start_period) == 12, 1, 0),
  period_counter = .I
)]

periods <- periods_dynamic
periods[1,]$year <- periods[1,]$year - 1

periods <- periods[year >= 2000,]
periods[, period_counter := .I]
periods[, period := paste0("Period_", .I)]   


## Start/end per deployment ---------------------------------------------------

deployments <- dat[
  !is.na(sensor_start_date) & !is.na(sensor_end_date),
  .(start = min(sensor_start_date),
    end   = max(sensor_end_date)),
  by = .(project_id, deployment_location_id)
][
  , proj_depl := paste(project_id, deployment_location_id, sep = "_")
]
cat("Number of unique deployments:", nrow(deployments), "\n")  


## Weekly bins for each period (13 weeks × 7 days) ----------------------------

# Rebuild period_weeks from this
max_weeks <- 13

period_weeks <- periods[, {
  dates <- seq(start_period, end_period, by = "1 day")
  week  <- rep(1:max_weeks, each = 7)[seq_along(dates)]
  list(date = dates, week = week)
}, by = .(period_counter, season, year, start_period, end_period)]

periods[, `:=`(start_period = as.IDate(start_period),
               end_period   = as.IDate(end_period))]


## Expand deployments → daily effort ------------------------------------------

effort_daily <- deployments[
  , .(date = seq(start, end, by = "1 day")), 
  by = proj_depl
]

effort_daily <- effort_daily[
  period_weeks,
  on = .(date >= start_period, date <= end_period),
  .(proj_depl = x.proj_depl,      # x. = take from left table
    date,
    week,
    period_counter,
    season,
    year)
][!is.na(period_counter) & !is.na(proj_depl)]
cat("Daily effort rows created:", nrow(effort_daily), "\n")


## Consolidate to weekly values -----------------------------------------------

# Effort (days camera was on per week)
effort_weekly <- effort_daily[
  , .(effort_days = .N),
  by = .(proj_depl, period_counter, week)
] 
# okay is >7 - this is summing across multiple cameras per cell 

# Detections (1/0) 
dat_sp[, proj_depl := paste(project_id, deployment_location_id, sep = "_")]
date_lookup <- unique(period_weeks[, .(date, week, period_counter)])
detections_with_period <- dat_sp[
  date_lookup,
  on = .(record_date = date),    
  nomatch = NULL                 
]

detections_weekly <- detections_with_period[
  , .(detected = 1L),
  by = .(proj_depl, period_counter, week)
]


## Full site × period × week grid (including zeros) ---------------------------

# Full grid 
full_grid <- CJ(
  proj_depl      = unique(deployments$proj_depl),
  period_counter = periods$period_counter,
  week           = 1:max_weeks
)

# Merge effort
y_effort <- effort_weekly[full_grid, on = .(proj_depl, period_counter, week)]
y_effort[is.na(effort_days), effort_days := 0L]

# Merge detections
y_detect <- detections_weekly[full_grid, on = .(proj_depl, period_counter, week)]
y_detect[is.na(detected), detected := 0L]

# Combine
y_data <- y_effort[y_detect, on = .(proj_depl, period_counter, week)]


## Spatial aggregation to 10×10 km2 grid cells --------------------------------

need_cell_lookup <- "NO"

if(need_cell_lookup == "YES"){
  
  # WI data 
  overview_seq <- fread("WI data/sequences_updated_20240710.csv")
  overview_images <- fread("WI data/images_updated_20240714.csv")
  
  # Unique proj_depl locations
  loc_seq <- overview_seq |>
    dplyr::select(project_id, deployment_location_id, longitude, latitude) |>
    distinct() |>
    collect()
  loc_seq <- as.data.frame(loc_seq) %>% 
    mutate(longitude = round(as.numeric(longitude), 4),
           latitude = round(as.numeric(latitude), 5))
  
  loc_images <- overview_images |>
    dplyr::select(project_id, deployment_location_id, longitude, latitude) |>
    distinct() |>
    collect()
  
  loc_images <- as.data.frame(loc_images) %>% 
    mutate(longitude = as.numeric(longitude)) %>% 
    mutate(latitude = as.numeric(latitude))
  
  # NAs are fine - there is a row that is the header 
  loc_images <- loc_images[!is.na(loc_images$longitude),] %>% 
    mutate(longitude = round(as.numeric(longitude), 4),
           latitude = round(as.numeric(latitude), 5))
  
  loc <- rbind(loc_seq, loc_images) %>% 
    distinct() %>% 
    drop_na() %>% 
    mutate(proj_depl = paste(project_id, deployment_location_id, sep="_"))
  
  # Reproject loc 
  points <- vect(loc, geom = c("longitude", "latitude"), crs = "EPSG:4326")
  points_proj <- project(points, crs(global_cell_id))
  
  # Extract cell_ID values for each point
  extracted <- extract(global_cell_id, 
                       points_proj, 
                       method = "simple") 
  
  # Merge
  loc$cell_ID <- extracted$cell_ID[match(1:nrow(loc), extracted$ID)]
  cell_lookup <- loc
  
  # Save
  write.csv(cell_lookup, "WI data/WI_loc_matching_cell_ID_10km2.csv", row.names=F)
  rm(loc, points, points_proj, loc_images, loc_seq, overview_images, overview_seq)
  
} else {
  cell_lookup <- fread("WI data/WI_loc_matching_cell_ID_10km2.csv")
}

# Cell look-up
setDT(cell_lookup)
cell_lookup_dt <- cell_lookup[, .(proj_depl = paste(project_id, deployment_location_id, sep = "_"),
                                  cell_ID)
][ , .SD[1], by = proj_depl]
cell_lookup_dt[, proj_depl := as.character(trimws(proj_depl))]
y_data[, proj_depl := as.character(trimws(proj_depl))]

# Join cell_ID
y_data <- cell_lookup_dt[y_data, on = "proj_depl"]
cat("Unmatched deployments:", sum(is.na(y_data$cell_ID)), "\n")
cat("Matching rate:", round(mean(!is.na(y_data$cell_ID)) * 100, 1), "%\n")
y_data <- y_data[!is.na(cell_ID)] #should be 0 cases 

# Aggregate to cell level
y_agg <- y_data[
  , .(
    effort = sum(effort_days, na.rm = TRUE),           
    y = as.integer(any(detected == 1, na.rm = TRUE))  # presence if detected at least once
  ),
  by = .(cell_ID, period_counter, week)
]

# Add period data 
y_agg <- periods[, .(period_counter, season, year)][y_agg, on = "period_counter"]


## Build final 3D arrays for spOccupancy::svcTPGOcc() -------------------------

sites <- sort(unique(y_agg$cell_ID))
periods_vec <- sort(unique(y_agg$period_counter))
n_sites <- length(sites)
n_periods <- length(periods_vec)
n_weeks <- 13

# Create arrays
y_array <- array(NA_integer_, dim = c(n_sites, n_periods, n_weeks))
#effort_array <- array(0L, dim = c(n_sites, n_periods, n_weeks))
effort_array <- array(NA_integer_, dim = c(n_sites, n_periods, n_weeks))

# Index
idx <- y_agg[, .(
  i = match(cell_ID, sites),
  j = match(period_counter, periods_vec),
  k = week,
  y = y,
  effort = effort
)]

# Fill effort (still correct)
effort_array[cbind(idx$i, idx$j, idx$k)] <- idx$effort

# Only fill y where effort > 0
has_effort <- effort_array > 0

# Set surveyed-but-not-detected to 0
y_array[has_effort] <- 0L

# Then overwrite with actual detections (only possible where effort > 0)
y_array[cbind(idx$i[idx$y == 1], idx$j[idx$y == 1], idx$k[idx$y == 1])] <- 1L

# Quick checks
dim(y_array)
sum(y_array, na.rm = TRUE)          # total detections 
sum(effort_array > 0)               # number of site-weeks with effort
sum(is.na(y_array))                  
sum(y_array == 0 & effort_array == 0, na.rm = TRUE)  # should be 0

# Save
filename <- paste("Data for modelling/", target_species, ".RData", sep = "")
save(target_species, y_array, effort_array, periods, sites, reference_species, 
     y_data, y_agg, global_cell_id, gbif_species, file = filename)
