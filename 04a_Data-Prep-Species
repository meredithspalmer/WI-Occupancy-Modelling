  ## Generate y_array and effort_array ------------------------------------------
  
  ## Add cell_ID ---
  dat <- merge(dat,
               wi_match_cell_ids[, .(project_id, deployment_location_id, cell_ID)],
               by = c("project_id", "deployment_location_id"),
               all.x = TRUE)
  
  dat_sp <- merge(dat_sp,
                  wi_match_cell_ids[, .(project_id, deployment_location_id, cell_ID)],
                  by = c("project_id", "deployment_location_id"),
                  all.x = TRUE)
  
  # Remove missing/invalid cell_ID
  sum(is.na(dat$cell_ID)) #should be 0 
  dat   <- dat[!is.na(cell_ID) & cell_ID != ""]
  sum(is.na(dat_sp$cell_ID)) #should be 0 
  dat_sp <- dat_sp[!is.na(cell_ID) & cell_ID != ""]
  
  cat("Rows after removing NA/invalid cell_ID:\n")
  cat("  dat:   ", nrow(dat), "\n")
  cat("  dat_sp:", nrow(dat_sp), "\n")
  cat("Any remaining NA cell_ID in dat?   ", any(is.na(dat$cell_ID)), "\n")
  cat("Any remaining NA cell_ID in dat_sp?", any(is.na(dat_sp$cell_ID)), "\n")
  
  # Unique cells (sites)
  cells   <- sort(unique(c(dat$cell_ID, dat_sp$cell_ID)))
  n_cells <- length(cells)
  cell_idx_dt <- data.table(cell_ID = cells, cell_idx = seq_len(n_cells))
  
  
  ## Generate 91-day primary periods ---
  
  # Set up periods
  min_start <- min(dat$sensor_start_date, na.rm = TRUE)
  max_end <- max(dat$sensor_end_date, na.rm = TRUE)
  
  start_dec <- as.IDate(paste(year(min_start) - 1, "12-01", sep = "-"))
  period_starts <- seq(start_dec, max_end, by = "91 days")
  period_starts <- as.Date(period_starts)
  
  periods_dynamic <- data.table(start_period = period_starts,
                                end_period = c(period_starts[-1] - 1, NA_Date_)
  )[!is.na(end_period)]
  
  periods_dynamic[, `:=`(
    period_counter = .I,
    season = rep(c("Winter", "Spring", "Summer", "Fall"), length.out = .N),
    year = year(start_period)   
  )]
  
  periods <- periods_dynamic[year >= 2000]
  periods[, `:=`(
    period = paste0("Period_", .I),
    period_counter = .I
  )]
  
  cat("Number of primary periods:", nrow(periods), "\n")
  print(head(periods, 4))
  
  # Per-period week lookup (weeks reset per period)
  period_weeks <- periods[, {
    dates <- seq(start_period, end_period, by = "1 day")
    week  <- rep(1:13, each = 7)[seq_along(dates)]
    list(date = dates, week = week)
  }, by = .(period_counter, season, year, start_period, end_period)]
  
  
  ## Effort --- 
  
  # Clean/format dat 
  deployments <- unique(dat[, .(cell_ID,
                                project_id,
                                deployment_location_id,
                                sensor_start_date = as.Date(sensor_start_date),
                                sensor_end_date   = as.Date(sensor_end_date))])
  
  deployments_valid <- deployments[
    !is.na(cell_ID) &
      !is.na(sensor_start_date) &
      !is.na(sensor_end_date) &
      sensor_start_date <= sensor_end_date
  ]
  
  cat("Valid deployment intervals:", nrow(deployments_valid), "\n")
  
  # Expand each interval individually
  effort_daily <- deployments_valid[, 
                                    .(date = seq(sensor_start_date, sensor_end_date, by = "1 day")),
                                    by = .(cell_ID, project_id, deployment_location_id, 
                                           sensor_start_date, sensor_end_date)
  ]
  effort_daily[, proj_depl := paste(project_id, deployment_location_id, sep = "_")]
  
  # Restrict to days inside defined periods
  effort_daily <- effort_daily[
    period_weeks,
    on = .(date >= start_period, date <= end_period),
    .(cell_ID, proj_depl, date, week, period_counter)
  ][!is.na(cell_ID) & !is.na(period_counter)]
  
  # Aggregate trap-days
  effort_sum <- effort_daily[,
                             .(effort_days = .N),
                             by = .(cell_ID, period_counter, week)
  ]
  effort_sum <- merge(effort_sum, cell_idx_dt, by = "cell_ID")
  
  sum(is.na(effort_sum$cell_idx)) #should be 0 
  effort_sum <- effort_sum[!is.na(cell_idx)]
  
  cat("Final effort rows (cell-weeks):", nrow(effort_sum), "\n")
  cat("Unique cells with effort:     ", uniqueN(effort_sum$cell_ID), "\n")
  cat("Any NA cell_idx?              ", any(is.na(effort_sum$cell_idx)), "\n")
  
  
  ## Detections ---
  
  dat_sp[, record_date := as.Date(record_date)]
  setkey(period_weeks, date)
  dat_sp_time <- period_weeks[dat_sp, on = .(date = record_date), nomatch = 0L]
  
  det_long <- unique(dat_sp_time[, .(cell_ID, period_counter, week)])
  det_long <- merge(det_long, cell_idx_dt, by = "cell_ID")
  sum(is.na(det_long$cell_idx)) #should be 0 
  det_long <- det_long[!is.na(cell_idx)]
  
  
  # ------------------------------------------------------------------
  # 6. Build 3D arrays + REMOVE UNSAMPLED SITES EARLY
  # ------------------------------------------------------------------
  
  n_periods <- nrow(periods)
  K <- 13L
  
  # Temporary full arrays (before filtering)
  y_arr_full <- array(NA_integer_, dim = c(n_cells, n_periods, K))
  effort_arr_full <- array(NA_integer_, dim = c(n_cells, n_periods, K))
  
  # Fill effort
  effort_arr_full[cbind(effort_sum$cell_idx,
                        effort_sum$period_counter,
                        effort_sum$week)] <- effort_sum$effort_days
  
  # Fill y
  has_effort_full <- !is.na(effort_arr_full) & effort_arr_full > 0
  y_arr_full[has_effort_full] <- 0L
  
  if (nrow(det_long) > 0) {
    y_arr_full[cbind(det_long$cell_idx,
                     det_long$period_counter,
                     det_long$week)] <- 1L
  }
  
  # ------------------------------------------------------------------
  # Identify cells to KEEP (those with at least some effort)
  # ------------------------------------------------------------------
  
  # Total effort per cell: sum across ALL periods and ALL weeks
  total_effort_per_cell <- apply(effort_arr_full, MARGIN = 1, FUN = sum, na.rm = TRUE)
  
  # Debug prints
  cat("Length of total_effort_per_cell:", length(total_effort_per_cell), "\n")
  cat("Max total effort:", max(total_effort_per_cell), "\n")
  cat("Number of cells with zero effort:", sum(total_effort_per_cell == 0), "\n")
  
  # Logical vector of length n_cells
  has_any_effort <- total_effort_per_cell > 0
  
  # Confirm it's correct length
  stopifnot(length(has_any_effort) == dim(effort_arr_full)[1])
  
  # Now safe
  keep_idx <- which(has_any_effort)
  
  cat("Keeping", length(keep_idx), "cells with effort > 0\n")
  
  # Your safety check should now pass
  if (any(keep_idx > dim(effort_arr_full)[1])) {
    stop("keep_idx out of bounds - impossible with correct rowSums/apply")
  }
  
  n_removed <- sum(!has_any_effort)
  if (n_removed > 0) {
    cat("\nRemoving", n_removed, "cells with zero total effort\n")
    cat("Removed cell_IDs (sample):", head(sort(cells[!has_any_effort]), 20), "...\n")
  }
  
  # Subset
  cells_clean <- cells[keep_idx]
  n_cells_clean <- length(cells_clean)
  
  y_arr    <- y_arr_full[keep_idx, , , drop = FALSE]
  effort_arr <- effort_arr_full[keep_idx, , , drop = FALSE]
  
  # Update dimnames
  dimnames(y_arr) <- list(cell_ID = as.character(cells_clean),
                          period = periods$period,
                          rep = 1:K)
  dimnames(effort_arr) <- dimnames(y_arr)
  
  # Continuous effort
  effort_3d <- array(0.0, dim = dim(y_arr))
  effort_3d[!is.na(effort_arr)] <- effort_arr[!is.na(effort_arr)]
  dimnames(effort_3d) <- dimnames(y_arr)
  
  # Optional: update effort_sum and det_long for downstream use
  effort_sum <- effort_sum[cell_ID %in% cells_clean]
  det_long   <- det_long[cell_ID %in% cells_clean]
  
  # ------------------------------------------------------------------
  # Final checks
  # ------------------------------------------------------------------
  cat("\n=== FINAL CHECKS ===\n")
  cat("Original cells:", n_cells, "→ After cleaning:", n_cells_clean, "\n")
  cat("Any remaining all-NA rows in y_arr?", any(apply(is.na(y_arr), 1, all)), "\n")
  cat("Total detections:", sum(y_arr == 1, na.rm = TRUE), "\n")
  cat("Max effort in any cell-week:", max(effort_arr, na.rm = TRUE), "\n")
  
  y_array      <- y_arr
  effort_array <- effort_3d    
  sites        <- cells_clean
  deployments  <- deployments_valid
  
  # Save
  filename <- paste0("Data for modelling/", target_species, ".RData")
  save(target_species, y_array, effort_array, periods, sites, reference_species, 
       deployments, effort_sum, cell_idx_dt, file = filename)
}
