  ggplot() +
    geom_tile(data = range_map_df, aes(x = x, y = y, fill = value)) +
    scale_fill_viridis_c(na.value = "white") +
    geom_sf(data = dat_sp_inside_sf, color = "red", size = 1) +
    theme_minimal() + labs(title = "Sightings points inside mmd_map",
