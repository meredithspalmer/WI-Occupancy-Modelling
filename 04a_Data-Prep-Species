  # Extract raster values at site locations
  coords_proj <- st_coordinates(sites_sf)
  cells <- terra::cellFromXY(mmd_map, coords_proj)
  vals <- terra::values(mmd_map)[cells]
  
  # Sites overlapping mmd range
