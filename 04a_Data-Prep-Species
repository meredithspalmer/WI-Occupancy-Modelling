# Generating reference raster & matching WI to cell_IDs
need_to_run <- "NO" 

if(need_to_run == "YES"){
  
  # Load raster + cell_ID
  reference <- rast("Raw spatial layers/Global_1km_CEA_reference_raster.tif")
  cell_id_layer <- init(reference, fun = "cell")   
  reference_with_id <- c(reference, cell_id_layer)
  names(reference_with_id) <- c("Global_reference_raster_1km_CEA", "cell_ID")
  reference <- reference_with_id
  rm(reference_with_id, cell_id_layer) 
  
  # Save
  writeRaster(reference, "1x1 km spatial layers/reference_1km2.tif",
              overwrite = TRUE, datatype = "INT4S")
  
  # Create WI site matching - load and format species data 
  overview_seq    <- fread("WI data/sequences_updated_20240710.csv")
  overview_images <- fread("WI data/images_updated_20240714.csv")
  
  loc <- bind_rows(
    overview_seq |> select(project_id, deployment_location_id, longitude, latitude),
    overview_images |> select(project_id, deployment_location_id, longitude, latitude)) |>
    distinct() |> 
    collect() |>                             
    mutate(longitude = as.numeric(longitude),
           latitude = as.numeric(latitude)) |>
    filter(!is.na(longitude), !is.na(latitude)) |>   
    mutate(longitude = round(longitude, 4),
           latitude = round(latitude, 5),
           proj_depl = paste(project_id, deployment_location_id, sep = "_")) |>
    distinct(proj_depl, longitude, latitude, .keep_all = TRUE)   
  
  loc_sf <- loc |>
    st_as_sf(coords = c("longitude", "latitude"), crs = 4326, remove = FALSE) |>  
    st_transform(crs(reference))  
  
  # Extract cell_ID from raster
  loc_cell <- terra::extract(reference, vect(loc_sf))  
  
  # Combine and deduplicate by proj_depl (keep first cell_ID if point falls in multiple)
  loc_cell_ID <- loc_sf |>
    mutate(cell_ID = loc_cell$cell_ID) |>
    st_drop_geometry() |>   
    group_by(proj_depl) |>
    slice_head(n = 1) |>    
    ungroup()
  
  # Save
  fwrite(loc_cell_ID, "WI data/WI_loc_matching_cell_ID_1km2.csv")
  
  # Clean environment
  rm("loc", "loc_cell", "loc_cell_ID", "loc_sf", "overview_images", "overview_seq")
  gc()
  
} 

