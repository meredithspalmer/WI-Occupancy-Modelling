  # Bounding box 
  ext_bbox <- st_bbox(mmd_map) 
  x_buffer <- (ext_bbox["xmax"] - ext_bbox["xmin"]) * 0.01
  y_buffer <- (ext_bbox["ymax"] - ext_bbox["ymin"]) * 0.01
  
