  # Save plot
  if(to_plot == TRUE){
    species_dir <- file.path("Model outputs", species_file) 
    if (!dir.exists(species_dir)) {dir.create(species_dir, recursive = TRUE)}
    plot_file <- file.path(species_dir, paste0(species_file, "_deployment_plot_original.png"))
    ggsave(filename = plot_file, plot = last_plot(), width = 10, height = 6, dpi = 300)
