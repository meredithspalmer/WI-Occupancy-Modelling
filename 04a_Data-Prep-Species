    "Hystrix cristata"       = "2009-06-01",
    "Leptailurus serval"     = "2009-06-01",
    "Loxodonta africana"     = "2008-12-01",
    "Lupulella mesomelas"    = "2009-06-01",
    "Lycaon pictus"          = "2017-01-01",
    "Lynx pardinus"          = "2020-01-01",
    "Mazama americana"       = "2008-07-01",
    "Melursus ursinus"       = "2014-11-01",
    "Nasua nasua"            = "2008-07-01",
    "Panthera leo"           = "2009-06-01",
    "Panthera onca"          = "2008-01-01",
    "Panthera uncia"         = "2009-06-01",
