## Protected area status ---

# Load polygons 
wdpa <- rbind(
  st_read("Raw spatial layers/WDPA_Jan2025_Public_shp/WDPA_Jan2025_Public_shp_0/WDPA_Jan2025_Public_shp-polygons.shp"),
  st_read("Raw spatial layers/WDPA_Jan2025_Public_shp/WDPA_Jan2025_Public_shp_1/WDPA_Jan2025_Public_shp_1/WDPA_Jan2025_Public_shp-polygons.shp"),
  st_read("Raw spatial layers/WDPA_Jan2025_Public_shp/WDPA_Jan2025_Public_shp_2/WDPA_Jan2025_Public_shp-polygons.shp")
)

if (st_crs(wdpa) != st_crs(mmd_poly)) {
  wdpa <- st_transform(wdpa, st_crs(mmd_poly))
}

wdpa      <- st_make_valid(wdpa)
mmd_poly  <- st_make_valid(mmd_poly)

# Keep only PAs that intersect the species range
wdpa_aoi_sf <- suppressWarnings(st_intersection(wdpa, mmd_poly))
wdpa_aoi_sf <- wdpa_aoi_sf[!st_is_empty(wdpa_aoi_sf), ]
cat("Number of WDPA polygons intersecting species range:", nrow(wdpa_aoi_sf), "\n")
wdpa_aoi_vect <- vect(wdpa_aoi_sf)

# Create fractional cover stack – one layer per year
unique_years <- sort(unique(periods$year))
pa_layers    <- list()

for (yr in unique_years) {
  
  # Subset to PAs designated <= this year
  active <- wdpa_aoi_vect[wdpa_aoi_vect$STATUS_YR <= yr, ]
  
  if (nrow(active) == 0) {
    # No protection → all cells get 0
    frac <- reference_species
    values(frac) <- 0
    
  } else {
    # Fractional cover = proportion of cell covered by any PA
    frac <- rasterize(active, 
                      reference_species, 
                      cover = TRUE,          # ← this gives fraction (0–1)
                      background = 0,        # cells with no overlap get 0
                      na.rm = TRUE)          # usually not needed here, but safe
  }
  
  pa_layers[[paste0("protected_frac_", yr)]] <- frac
  cat(sprintf("Year %d: %d active PAs → layer created\n", yr, nrow(active)))
}

# Combine into multi-layer SpatRaster with cell_ID
pa_stack <- rast(pa_layers)
cell_id_rast <- crop(global_cell_id, reference_species, snap = "out")
full_stack   <- c(cell_id_rast, pa_stack)
full_stack   <- mask(full_stack, reference_species, maskvalues = NA)

# Convert to data frame
df_wide <- as.data.frame(full_stack, na.rm = TRUE, xy = TRUE)
setDT(df_wide)
prot_cols <- grep("^protected_", names(df_wide), value = TRUE)

# Melt to long format 
pa_df_long <- melt(df_wide,
                   id.vars       = c("x", "y", "cell_ID"),
                   measure.vars  = prot_cols,
                   variable.name = "year_var",
                   value.name    = "protected_prop")

# Clean year column
pa_df_long <- setDT(pa_df_long)
pa_df_long[, year := as.integer(gsub("protected_frac_", "", year_var))]
pa_df_long[, year_var := NULL]

# Join with periods
periods_join <- periods[, .(year, period_counter, season, ys_key)]
wdpa_data <- pa_df_long[
  periods_join,
  on = "year",
  allow.cartesian = TRUE
]
setorder(wdpa_data, cell_ID, year, period_counter)
wdpa_data <- wdpa_data %>% dplyr::select(c(cell_ID, protected_prop, period_counter, year))

# Check cells and years present 
print(length(unique(wdpa_data$cell_ID)) == length(sites))
print(unique(wdpa_data$year))

# Clean workspace
rm(pa_df_long, df_wide, prot_cols); gc()

# Format for OM 
hist(wdpa_data$protected_prop)    
hist(log(wdpa_data$protected_prop)) 

wdpa_predict <- wdpa_data %>% 
  filter(cell_ID %in% sites_predict) %>% 
