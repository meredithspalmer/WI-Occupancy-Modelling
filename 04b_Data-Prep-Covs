# Set unique ID 
setDT(y_data)
deploy_map <- unique(y_data[, .(proj_depl)])
deploy_map[, deploy_id := .I]  

# For each cell-period, take the first deploy_id
y_data <- deploy_map[y_data, on = "proj_depl"]
