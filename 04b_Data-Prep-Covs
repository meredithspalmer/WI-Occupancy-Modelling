  pivot_wider(id_cols = cell_ID, names_from = period_counter, values_from = protected_prop, 
              values_fill = NA) %>%
  arrange(cell_ID) %>% 
  dplyr::select(-cell_ID) %>% 
  as.matrix()
dim(wdpa_predict)

wdpa_model <- wdpa_data %>% 
