# Map new periods to temp_data 
temp_data[, ys_key := paste(year, fcase(period_counter %% 4 == 1, "Winter",
                                        period_counter %% 4 == 2, "Spring",
                                        period_counter %% 4 == 3, "Summer",
                                        period_counter %% 4 == 0, "Fall",
                                        default = NA_character_), sep = "__")]
# ys_key in periods (model periods)
periods[, ys_key := paste(year, season, sep = "__")]

# Lookup table: model period_counter by season-year key
lookup <- unique(periods[, .(ys_key, model_period_counter = period_counter)])

# Perform left join: keep all temp_data rows, add matching model period_counter
temp_periods <- merge(temp_data, lookup, by = "ys_key", all.x = TRUE)

# Drop rows that didn't match any model period (no corresponding season-year)
temp_periods <- temp_periods[!is.na(model_period_counter)]

# Rename to match model naming
temp_periods[, period_counter :=  NULL]
setnames(temp_periods, "model_period_counter", "period_counter")
temp_periods[, ys_key := NULL]

# Now place into full grid to guarantee dimension
