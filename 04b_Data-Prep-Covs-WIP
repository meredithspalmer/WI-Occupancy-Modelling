  a
}

## Number of unique deployments per cell-period
n_depl_per_cell_period <- effort_daily[,
                                       .(n_depl = uniqueN(proj_depl)),
                                       by = .(cell_ID, period_counter)
]

# Map to cell_idx
n_depl_per_cell_period <- merge(n_depl_per_cell_period, cell_idx_dt, by = "cell_ID")

# Build 2D matrix first (cell × period)
ndepl_2d <- matrix(0L, nrow = n_cells, ncol = n_periods,
                   dimnames = list(cells, periods$period))

ndepl_2d[cbind(n_depl_per_cell_period$cell_idx,
               n_depl_per_cell_period$period_counter)] <-
  n_depl_per_cell_period$n_depl

# Expand to 3D (same value for every week in the period)
ndepl <- array(ndepl_2d, dim = c(n_cells, n_periods, K))
dimnames(ndepl) <- dimnames(y_arr)

# ------------------------------------------------------------------
# 2. Project ID covariate (first deploy_id per cell-period)
# (your example assigns a unique integer to each proj_depl)
# ------------------------------------------------------------------
# If you want to recreate this exactly, you need proj_depl info per cell-period
# Alternative: use a simple sequence or random effect index
deploy_map <- unique(effort_daily[, .(proj_depl)])
deploy_map[, deploy_id := .I]
# Join back and take first deploy_id per cell-period
effort_daily_with_id <- merge(effort_daily,
                              deploy_map,
                              by = c("proj_depl"))
proj_dt <- effort_daily_with_id[,
                                .(deploy_id = first(deploy_id)),
                                by = .(cell_ID, period_counter)
]
proj_dt <- merge(proj_dt, cell_idx_dt, by = "cell_ID")
proj_2d <- matrix(0L, nrow = n_cells, ncol = n_periods,
                  dimnames = list(cells, periods$period))
proj_2d[cbind(proj_dt$cell_idx, proj_dt$period_counter)] <- proj_dt$deploy_id
proj <- array(proj_2d, dim = c(n_cells, n_periods, K))
dimnames(proj) <- dimnames(y_arr)
